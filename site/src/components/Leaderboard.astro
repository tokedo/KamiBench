---
// Leaderboard data source. To make this dynamic later, replace this import with a
// fetch to the leaderboard API endpoint — a one-line change:
//   const data = await (await fetch('https://<api>/leaderboard')).json();
import data from '../data/leaderboard.json';

interface Entry {
  model: string;
  org: string;
  status: string;
  metrics: Record<string, string | number>;
}

// Placeholder for now: entries stay empty until the study design (models, metrics,
// scoring) is settled, so the section renders as an intentional pending state.
const entries = data.entries as Entry[];
---

<div class="leaderboard">
  {
    entries.length === 0 ? (
      <div class="placeholder">
        <span class="chip chip-pending">Pending</span>
        <p>{data.note}</p>
      </div>
    ) : (
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Model</th>
              <th scope="col">Organization</th>
              <th scope="col">Status</th>
            </tr>
          </thead>
          <tbody>
            {entries.map((entry) => (
              <tr>
                <td>{entry.model}</td>
                <td>{entry.org}</td>
                <td>
                  <span class={`chip ${entry.status === 'pending' ? 'chip-pending' : 'chip-ok'}`}>
                    {entry.status}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
  {data.updated && <p class="leaderboard-note label">Updated {data.updated}</p>}
</div>
