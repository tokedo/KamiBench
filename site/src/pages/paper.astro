---
import Base from '../layouts/Base.astro';
import { renderPaper } from '../lib/paper';
// Single source of truth: the paper is read from the repo root at build time,
// so every push re-renders this page with no manual sync step.
import paperSource from '../../../paper/paper.md?raw';

const { html, headings } = renderPaper(paperSource);
---

<Base
  title="KamiBench: A Persistent, Auditable World for Long-Horizon Agent Evaluation"
  description="Position-and-system paper — openness extended from code to execution, Kamigotchi as the best-fit instance, and the released system with a two-month feasibility pilot; empirical claims land as registered experiments complete."
  path="/paper"
  ogType="article"
>
  <div class="paper-shell">
    <nav class="toc" aria-label="Table of contents">
      <span class="label">Contents</span>
      <ol>
        {
          headings.map((h) => (
            <li>
              <a href={`#${h.id}`}>{h.text}</a>
            </li>
          ))
        }
      </ol>
    </nav>
    <article class="paper">
      <Fragment set:html={html} />
    </article>
  </div>
</Base>
