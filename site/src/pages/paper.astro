---
import Base from '../layouts/Base.astro';
import { renderPaper } from '../lib/paper';
// Single source of truth: the paper is read from the repo root at build time,
// so every push re-renders this page with no manual sync step.
import paperSource from '../../../paper/paper.md?raw';

const { html, headings } = renderPaper(paperSource);
---

<Base
  title="KamiBench: An Autonomous On-Chain World as a Benchmark for Long-Horizon, Self-Sustaining Agents"
  description="Position paper + pilot report — the autonomous-world substrate, Kamigotchi as an instance, and three released artifacts with a two-month autonomous pilot; remaining work is sequenced in the Research Roadmap."
  path="/paper"
  ogType="article"
>
  <div class="paper-shell">
    <nav class="toc" aria-label="Table of contents">
      <span class="label">Contents</span>
      <ol>
        {
          headings.map((h) => (
            <li>
              <a href={`#${h.id}`}>{h.text}</a>
            </li>
          ))
        }
      </ol>
    </nav>
    <article class="paper">
      <Fragment set:html={html} />
    </article>
  </div>
</Base>
