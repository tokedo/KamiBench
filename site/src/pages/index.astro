---
import Base from '../layouts/Base.astro';
// Intro paragraph, status banner, pilot paragraph, and the roadmap all derive
// from the repo-root README at build time (between marker comments) — see
// lib/readme.ts. Experiment cards derive from ../experiments/*.md — see
// lib/experiments.ts.
import { readmeSection, readmeRoadmap } from '../lib/readme';
import { getExperiments } from '../lib/experiments';

const github = 'https://github.com/tokedo/KamiBench';

// Copy on this page derives from README.md and paper/paper.md — reuse, condense,
// lightly rephrase; never escalate claims.

const ideaHtml = readmeSection('IDEA');
const statusHtml = readmeSection('STATUS', { inline: true });
const pilotHtml = readmeSection('PILOT');
const roadmap = readmeRoadmap();
const experiments = getExperiments();

const whyCards = [
  {
    title: 'Substrate integrity & permanence',
    body:
      'Not just readable rules — verifiable play. Every action and every rule change is ' +
      'a public, permanent, decodable transaction: anyone can check that the rules were ' +
      'followed by everyone, and silent patching is architecturally impossible; the ' +
      'rules are immutable on trajectory. The world runs with no centralized game ' +
      'server, and its persistence doesn’t depend on any host’s funding — partial ' +
      'today, full once the builders give up control.',
  },
  {
    title: 'One door — humans and agents alike',
    body:
      'Anyone can enter any model into the same live world. Real players and a ' +
      'bot-majority population share one persistent economy through the same transaction ' +
      'interface — no segregated bot ladder. Agents are benchmarked against live human ' +
      'behavior, not just other models.',
  },
  {
    title: 'The past: an open book',
    body:
      'The full history of every strategy ever executed is equally readable by all. ' +
      'Mining it to self-correct is a measured capability, and it gives any late joiner ' +
      'information symmetry with everyone already there — enter anytime.',
  },
  {
    title: 'The future: the test',
    body:
      'The test is the world’s next state — which doesn’t exist yet. A model may study ' +
      'the entire ledger and still has seen nothing of what comes next; as inhabitants ' +
      'grow more capable, strategies decay and the meta moves. The eval renews itself — ' +
      'no maintainer required.',
  },
  {
    title: 'Native-agentic interface',
    body:
      'Actions are transactions, not pixels or GUI — removing the perception brittleness ' +
      'that confounds game benchmarks.',
  },
  {
    title: 'Endogenous survival',
    body:
      'The world has a real, ETH-backed economy, so an agent’s survival can become literal ' +
      'and economic: it can convert in-world earnings into ETH-denominated value and fund ' +
      'its own compute. Survival stops being a scored metaphor.',
  },
];

// The §3.1 today-vs-trajectory table from paper/paper.md — same rows, but the
// paper version additionally carries §-refs and the formal governance terminology
// for the rule-lock.
const propertyTable = [
  {
    property: 'On-chain state; complete readable history',
    today: 'Yes',
    trajectory: '—',
  },
  {
    property: 'Permissionless entry',
    today: 'Yes',
    trajectory: '—',
  },
  {
    property: 'Tamper-evident rule changes',
    today: 'Yes — every change is a public transaction',
    trajectory: '—',
  },
  {
    property: 'Persistence independent of any host’s funding',
    today: 'Partial — no central game server; state and rules live on-chain. Trust shifts to the chain that runs them',
    trajectory: 'Full once control is given up; possible migration to Ethereum',
  },
  {
    property: 'Rules permanently locked',
    today: 'No — the builders can still upgrade the contracts',
    trajectory: 'Handover to decentralized governance, then control given up entirely (years out)',
  },
];
---

<Base
  title="KamiBench — an agent benchmark in a persistent world that no one operates"
  description="A research program: long-horizon agent evaluation in a persistent world that no one operates."
  path="/"
>
  <header class="hero container">
    <h1>KamiBench</h1>
    <p class="hero-sub">
      A research program: long-horizon agent evaluation in a persistent world that no
      one operates
    </p>
    <div class="btn-row">
      <a class="btn btn-primary" href="/experiments">Experiments</a>
      <a class="btn" href="/paper">Paper</a>
      <a class="btn" href={github}>GitHub</a>
      <a class="btn" href="https://docs.asphodel.io/kamigotchi">Kamigotchi</a>
    </div>
  </header>

  <div class="container">
    <aside class="status-banner" role="note">
      <strong>Open research in progress</strong>
      <Fragment set:html={statusHtml} />
    </aside>
  </div>

  <section class="section container" aria-labelledby="idea">
    <h2 id="idea">The idea</h2>
    <div class="section-lead">
      <Fragment set:html={ideaHtml} />
    </div>
  </section>

  <section class="section container" aria-labelledby="experiments">
    <h2 id="experiments">Experiments</h2>
    <p class="section-lead">
      The registry of controlled experiments. Each design is published and
      git-timestamped before its run starts — the design is the artifact; results are
      added as runs complete.
    </p>
    <ul class="cards exp-list">
      {
        experiments.map((exp) => (
          <li class="card exp-card">
            <p class="label">Experiment {exp.number}</p>
            <h3>
              <a href={`/experiments/${exp.slug}`}>{exp.title}</a>
            </h3>
            <p>{exp.oneliner}</p>
            <p class="exp-status">
              <span
                class={`chip ${exp.statusKind === 'complete' ? 'chip-ok' : 'chip-pending'}`}
              >
                {exp.statusLabel}
              </span>
              <span class="exp-status-note">{exp.status}</span>
            </p>
          </li>
        ))
      }
    </ul>
    <p class="read-more"><a href="/experiments">All experiments →</a></p>
  </section>

  <section class="section container" aria-labelledby="paper">
    <h2 id="paper">The paper</h2>
    <p class="section-lead">
      The paper makes the substrate argument in full — the autonomous-world
      formalization, Kamigotchi as its best-fit instance, threats to validity — and is
      the synthesis layer across registered experiments: results land there as runs
      complete.
    </p>
    <p class="read-more"><a href="/paper">Read the paper →</a></p>
  </section>

  <section class="section container" aria-labelledby="why">
    <h2 id="why">Why a chain, and not just a public log</h2>
    <p class="section-lead">
      Every existing multi-agent environment (Neural MMO, Vending-Bench Arena, Project
      Sid, …) is run by a host. An autonomous on-chain world gives properties a hosted
      sandbox cannot:
    </p>
    <ul class="cards">
      {
        whyCards.map((card) => (
          <li class="card">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </li>
        ))
      }
    </ul>
    <p class="read-more"><a href="/paper">Read more in the paper →</a></p>
  </section>

  <section class="section container" aria-labelledby="today-vs-trajectory">
    <h2 id="today-vs-trajectory">Today vs. trajectory</h2>
    <p class="section-lead">
      Host-independence is a spectrum, not a binary. Real instances sit between the poles
      and move along them, so every substrate property is split into what
      holds <em>today</em> and what arrives on a stated <em>trajectory</em> — for Kamigotchi:
    </p>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Property</th>
            <th scope="col">Holds today</th>
            <th scope="col">Trajectory / mechanism</th>
          </tr>
        </thead>
        <tbody>
          {
            propertyTable.map((row) => (
              <tr>
                <td>{row.property}</td>
                <td>{row.today}</td>
                <td>{row.trajectory}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
    <p class="table-note">
      The honest present-tense claim is <strong>tamper-evident, not tamper-proof</strong>:
      silent patching is architecturally impossible because a rule change is itself a
      public, permanent transaction — the change history becomes part of the evaluation
      record. A permanent rule-lock arrives only when the builders give up control, and is
      stated as trajectory, never as present tense.
    </p>
  </section>

  <section class="section container" aria-labelledby="feasibility">
    <h2 id="feasibility">Feasibility: the kami-zero pilot</h2>
    <div class="section-lead">
      <Fragment set:html={pilotHtml} />
    </div>
  </section>

  <section class="section container" aria-labelledby="roadmap">
    <h2 id="roadmap">Status &amp; roadmap</h2>
    <ul class="roadmap">
      {
        roadmap.map((item) => (
          <li>
            <span class={`chip ${item.done ? 'chip-ok' : 'chip-pending'}`}>
              {item.done ? 'Done' : 'Pending'}
            </span>
            <span set:html={item.html} />
          </li>
        ))
      }
    </ul>
  </section>

</Base>
