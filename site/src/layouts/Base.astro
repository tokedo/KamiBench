---
import '../styles/global.css';
// The footer disclosure renders from README.md's DISCLOSURE markers at build
// time — see lib/readme.ts.
import { readmeSection } from '../lib/readme';

interface Props {
  title: string;
  description: string;
  /** Path of the current page, used for the canonical URL, e.g. "/paper". */
  path?: string;
  /** OpenGraph type; the paper page is an article. */
  ogType?: 'website' | 'article';
}

const { title, description, path = '/', ogType = 'website' } = Astro.props;
const canonical = new URL(path, Astro.site);
// Versioned filename: scrapers (Discord, Twitter, Slack) cache og images by URL,
// so a content change must also change the URL to show up in new shares.
const ogImage = new URL('/og-v2.png', Astro.site);
const github = 'https://github.com/tokedo/KamiBench';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap.xml" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf9f7" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#131110" />
    <meta property="og:site_name" content="KamiBench" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="KamiBench — long-horizon agent evaluation in a persistent world that no one operates"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@0xTokedo" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      /* Google Analytics (GA4) — production builds only, so dev-server visits
         don't pollute the data. is:inline keeps Astro from bundling the tags. */
      import.meta.env.PROD && (
        <>
          <script
            is:inline
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-G0HWCTPZF7"
          ></script>
          <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-G0HWCTPZF7');
          </script>
        </>
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="container">
        <a class="wordmark" href="/">KamiBench</a>
        <nav class="site-nav" aria-label="Site">
          <a
            href="/experiments"
            aria-current={path.startsWith('/experiments') ? 'page' : undefined}>Experiments</a
          >
          <a href="/paper" aria-current={path === '/paper' ? 'page' : undefined}>Paper</a>
          <a href={github}>GitHub</a>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <h2>Disclosure</h2>
        <Fragment set:html={readmeSection('DISCLOSURE')} />
        <div class="footer-meta">
          <span><a href={`${github}/blob/main/LICENSE`}>MIT License</a></span>
          <span><a href={github}>GitHub</a></span>
          <span><a href="https://x.com/0xTokedo">@0xTokedo</a></span>
        </div>
      </div>
    </footer>
  </body>
</html>
